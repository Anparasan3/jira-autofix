# ══════════════════════════════════════════════════════════════════════════════
# @anpu/jira-autofix — environment variables
#
# Copy this file to .env in YOUR PROJECT ROOT (not in jira-autofix itself)
# and fill in the values. Never commit real credentials.
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# Jira (required)
# ──────────────────────────────────────────────
# Your Atlassian base URL — no trailing slash
JIRA_BASE_URL=https://yourteam.atlassian.net

# Your Atlassian account email
JIRA_EMAIL=you@example.com

# Jira API token — generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Project key shown in issue numbers, e.g. PROJ for PROJ-123
JIRA_PROJECT_KEY=PROJ

# ──────────────────────────────────────────────
# Anthropic (required)
# ──────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# ──────────────────────────────────────────────
# GitHub transport (optional — default: rest)
# ──────────────────────────────────────────────
# "rest" — call the GitHub REST API directly (requires GH_PAT or GITHUB_TOKEN)
# "cli"  — shell out to the `gh` CLI (must be installed & authenticated via `gh auth login`)
#          GH_PAT / GITHUB_TOKEN are NOT required in cli mode.
# GITHUB_MODE=rest

# ──────────────────────────────────────────────
# GitHub token (required in REST mode)
# ──────────────────────────────────────────────
# Personal Access Token with 'repo' scope (local dev / GitHub Actions secret)
# Create one at: https://github.com/settings/tokens
GH_PAT=ghp_

# GITHUB_TOKEN is injected automatically in GitHub Actions — no setup needed.
# GH_PAT takes priority when both are set.
# GITHUB_TOKEN=

# ──────────────────────────────────────────────
# Behaviour (optional)
# ──────────────────────────────────────────────
# Branch all PRs are opened against (default: master)
BASE_BRANCH=master

# Max number of issues to process per run (default: 3)
MAX_ISSUES=3

# Set to 'true' to preview without creating commits, pushes, or PRs
DRY_RUN=false

# ──────────────────────────────────────────────
# Agent tuning (optional)
# ──────────────────────────────────────────────
# Claude model to use — swap to Opus for complex multi-file issues,
# Haiku for fast/simple ones (default: claude-sonnet-4-6)
# JIRA_AUTOFIX_MODEL=claude-sonnet-4-6

# Claude max output tokens per issue (default: 8096)
# Raise to 16000+ when using Opus or expecting large rewrites
# JIRA_AUTOFIX_MAX_TOKENS=8096
