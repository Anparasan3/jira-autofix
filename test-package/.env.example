# ══════════════════════════════════════════════════════════════════════════════
# test-package — environment variables
#
# Copy to .env and fill in real values to run jira-autofix against this project.
# ══════════════════════════════════════════════════════════════════════════════

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=TEST

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-

# ── GitHub transport ──────────────────────────────────────────────────────────
# "rest" (default) — needs GH_PAT / GITHUB_TOKEN
# "cli"            — needs `gh` CLI authenticated via `gh auth login`
# GITHUB_MODE=rest

# ── GitHub token (REST mode only) ─────────────────────────────────────────────
GH_PAT=ghp_

# ── Behaviour ─────────────────────────────────────────────────────────────────
BASE_BRANCH=master
MAX_ISSUES=3
DRY_RUN=false

# ── Agent tuning ──────────────────────────────────────────────────────────────
# JIRA_AUTOFIX_MODEL=claude-sonnet-4-6
# JIRA_AUTOFIX_MAX_TOKENS=8096

# ── REST server (--mode=rest only) ────────────────────────────────────────────
# PORT=3000

# ── App token (used by src/middleware/auth.ts) ────────────────────────────────
API_TOKEN=test-secret
