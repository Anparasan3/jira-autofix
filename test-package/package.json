{
  "name": "test-package",
  "version": "1.0.0",
  "description": "Sample Bun app used to test jira-autofix as a real consumer.",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "jira-autofix": "bun run ../src/index.ts",
    "jira-autofix:serve": "bun run ../src/index.ts --mode=rest",
    "jira-autofix:fetch": "bun run ../src/stages/fetch.ts",
    "jira-autofix:fix": "bun run ../src/stages/fix.ts",
    "jira-autofix:open-prs": "bun run ../src/stages/openPrs.ts"
  },
  "dependencies": {
    "jira-autofix": "file:../dist"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
