{
  "name": "test-package",
  "version": "1.0.0",
  "description": "Sample Bun app used to test @anpu/jira-autofix as a real consumer.",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:programmatic": "bun test tests/programmatic.test.ts",
    "test:server": "bun test tests/server.test.ts",
    "jira-autofix": "bun run ../package/src/index.ts",
    "jira-autofix:serve": "bun run ../package/src/index.ts --mode=rest",
    "jira-autofix:fetch": "bun run ../package/src/stages/fetch.ts",
    "jira-autofix:fix": "bun run ../package/src/stages/fix.ts",
    "jira-autofix:open-prs": "bun run ../package/src/stages/openPrs.ts"
  },
  "dependencies": {
    "@anpu/jira-autofix": "file:../package/dist"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  },
  "engines": {
    "bun": ">=1.3"
  }
}
