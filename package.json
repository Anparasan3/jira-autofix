{
  "name": "jira-autofix",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run --cwd package build",
    "typecheck": "bun run --cwd package typecheck",
    "test": "bun run --cwd test-package test",
    "git:delete-tag": "git tag -d $(git tag -l 'v*') && git push --delete origin $(git tag -l 'v*')"
  },
  "workspaces": [
    "package"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  }
}
