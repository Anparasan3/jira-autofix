{
  "name": "@anpu/jira-autofix",
  "version": "1.1.0",
  "description": "Fetch open Jira issues, auto-fix them with Claude, and open GitHub PRs — works in any project.",
  "author": "Anparasan",
  "license": "MIT",
  "keywords": ["jira", "claude", "ai", "automation", "github", "pr", "autofix"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Anparasan3/jira-autofix"
  },
  "bin": {
    "jira-autofix": "./src/index.ts",
    "jira-autofix-fetch": "./src/stages/fetch.ts",
    "jira-autofix-fix": "./src/stages/fix.ts",
    "jira-autofix-open-prs": "./src/stages/openPrs.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "fetch": "bun run src/stages/fetch.ts",
    "fix": "bun run src/stages/fix.ts",
    "open-prs": "bun run src/stages/openPrs.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
